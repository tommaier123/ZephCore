-	.config = sx126x_lora_config,
-	.send = sx126x_lora_send,
-	.send_async = sx126x_lora_send_async,
-	.recv = sx126x_lora_recv,
-	.recv_async = sx126x_lora_recv_async,
-	.airtime = sx126x_lora_airtime,
-	.test_cw = sx126x_lora_test_cw,
+	.config          = sx126x_lora_config,
+	.send            = sx126x_lora_send,
+	.send_async      = sx126x_lora_send_async,
+	.recv            = sx126x_lora_recv,
+	.recv_async      = sx126x_lora_recv_async,
+	.airtime         = sx126x_lora_airtime,
+	.cad             = sx126x_lora_cad,
